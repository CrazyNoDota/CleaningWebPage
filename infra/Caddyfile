{
	email admin@shinex.kz
}

shinex.kz, www.shinex.kz {
	encode zstd gzip

	# Block Swagger docs from the public internet (defense-in-depth).
	# `respond` is ordered before `reverse_proxy` in Caddy's default
	# directive order, so these paths never reach the API.
	@apidocs path /api/docs /api/docs-json /api/docs/*
	respond @apidocs 404

	# API + WebSocket. NestJS already prefixes routes with /api/v1.
	@api path /api/* /socket.io/*
	reverse_proxy @api api:4000

	# Admin panel — basePath: '/admin' baked into the Next build.
	@admin path /admin /admin/*
	reverse_proxy @admin web-admin:3001

	# Everything else → marketing/booking site.
	reverse_proxy web-client:3000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
