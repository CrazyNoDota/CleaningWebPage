# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://cleaning:cleaning_dev@localhost:5432/cleaning?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=replace_me_in_production_access
JWT_REFRESH_SECRET=replace_me_in_production_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP (dev mode logs OTP to console; flip to false in prod)
OTP_DEV_MODE=true
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# SMS provider (mobizon | stub)
SMS_PROVIDER=stub
MOBIZON_API_KEY=

# Payments (stub | kaspi | freedom_pay | halyk_epay | cloudpayments)
PAYMENT_PROVIDER=stub

# WhatsApp Cloud API (Meta) — order-created alerts
# Set WHATSAPP_ENABLED=true to actually call the API; otherwise sends are logged only.
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_TEMPLATE_LANG=ru
# Approved Meta template names — see order-created-whatsapp.listener.ts for the variable contract
WHATSAPP_BUSINESS_TEMPLATE=
WHATSAPP_CUSTOMER_TEMPLATE=

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
